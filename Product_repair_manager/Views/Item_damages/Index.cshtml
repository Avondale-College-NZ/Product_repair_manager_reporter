@model IEnumerable<Product_repair_manager.Models.Item_damages>

@{
    ViewData["Title"] = "Item_damages";
}

<h1>Item_damages</h1>
<div class="container p- my-5 border border-4">

    <form asp-action="Index" method="get">
        <div class="form-actions no-color">
            <p>
                <label>Find by name: <input type="text" name="SearchString" value="@ViewData["CurrentFilter"]" /></label>
                <input type="submit" value="Search" class="btn btn-default" /> |
                <a asp-action="Index">Back to Full List</a> |
                <a class="button" asp-action="Create">Create New</a>
            </p>
        </div>
    </form>
<table class="table">
        <thead class="table-bordered table-dark">
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.ItemsId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.damage_type)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.severity)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.date)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.ItemsId)
            </td>
                <td>
                    @Html.DisplayFor(modelItem => item.damage_type)
                </td>
            <td>
                    @Html.DisplayFor(modelItem => item.severity)
            </td>
            <td>
                    @Html.DisplayFor(modelItem => item.date)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Item_damagesId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Item_damagesId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Item_damagesId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
