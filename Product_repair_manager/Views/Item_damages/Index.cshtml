@model IEnumerable<Product_repair_manager.Models.Item_damages>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.ItemId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.damage_report)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Item_date)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.ItemId)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.damage_report)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Item_date)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Item_damagesId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Item_damagesId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Item_damagesId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
